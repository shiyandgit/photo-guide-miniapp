.container {
  min-height: 100vh;
  background-color: #F0F4F8;
  padding-bottom: 40rpx;
}

/* 状态卡片 */
.status-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.status-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.status-content {
  display: flex;
  align-items: center;
}

.status-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #eee;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #999;
  margin-right: 20rpx;
}

.status-icon.active {
  background-color: #4CAF50;
  color: #fff;
}

.status-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.status-platform {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.status-key {
  font-size: 26rpx;
  color: #666;
}

.status-text {
  font-size: 30rpx;
  color: #999;
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: #eee;
  color: #999;
}

.status-badge.active {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  margin-top: 30rpx;
}

/* 平台选择 */
.platform-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.platform-item.active {
  border-color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.05);
}

.platform-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.platform-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.platform-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.platform-desc {
  font-size: 24rpx;
  color: #999;
}

/* 输入框 */
.input-wrapper {
  margin-bottom: 30rpx;
}

.form-input {
  height: 88rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* 按钮 */
.btn-outline {
  background-color: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.btn-outline::after {
  border: none;
}

.btn-danger {
  background-color: #fff;
  color: #f44336;
  border: 2rpx solid #f44336;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.btn-danger::after {
  border: none;
}

/* 操作卡片 */
.action-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

/* 错误提示 */
.error-tip {
  color: #f44336;
  font-size: 26rpx;
  margin-top: 20rpx;
  text-align: center;
}

/* 教程区域 */
.tutorial-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tutorial-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tutorial-item {
  border-bottom: 1rpx solid #F0F4F8;
  padding: 20rpx 0;
}

.tutorial-item:last-child {
  border-bottom: none;
}

.tutorial-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tutorial-name {
  font-size: 28rpx;
  color: #333;
}

.tutorial-arrow {
  font-size: 24rpx;
  color: #999;
}

.tutorial-content {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #F0F4F8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部说明 */
.footer-note {
  margin: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.footer-note text {
  font-size: 22rpx;
  color: #999;
}
