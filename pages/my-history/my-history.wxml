<view class="container">
  <view class="guide-list">
    <guide-card wx:for="{{guides}}" wx:key="_id" guide="{{item}}" bind:tap="goDetail" data-id="{{item._id}}" />
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty" wx:if="{{!loading && guides.length === 0}}">
    <text class="empty-icon">🐶</text>
    <text class="empty-text">暂无浏览记录，汪~</text>
  </view>

  <view class="no-more" wx:if="{{!loading && noMore && guides.length > 0}}">
    <text class="no-more-text">没有更多了</text>
  </view>
</view>
