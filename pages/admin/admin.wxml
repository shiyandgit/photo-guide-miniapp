<view class="container">
  <view class="header">
    <text class="header-title">全部攻略</text>
    <view class="refresh-btn" bindtap="refresh">刷新</view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="guide-list" wx:elif="{{guides.length > 0}}">
    <view class="guide-item" wx:for="{{guides}}" wx:key="_id">
      <view class="guide-main" bindtap="viewGuide" data-id="{{item._id}}">
        <image class="guide-cover" src="{{item.coverImage || '/images/default-cover.png'}}" mode="aspectFill" />
        <view class="guide-info">
          <text class="guide-title">{{item.title}}</text>
          <view class="guide-meta">
            <text class="guide-author">{{item.authorName || '匿名'}}</text>
            <text class="guide-status status-{{item.status}}">{{item.status === 'approved' ? '已通过' : item.status === 'pending' ? '待审核' : '已拒绝'}}</text>
          </view>
        </view>
      </view>
      <view class="guide-actions">
        <view class="action-view" bindtap="viewGuide" data-id="{{item._id}}">查看</view>
        <view class="action-delete" bindtap="deleteGuide" data-id="{{item._id}}" data-title="{{item.title}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无攻略数据</text>
  </view>
</view>
