<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goSearch">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索拍照攻略...</text>
    </view>
  </view>

  <!-- Banner 轮播 -->
  <swiper class="banner" indicator-dots autoplay circular interval="{{3000}}">
    <swiper-item wx:for="{{banners}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <image src="{{item.coverImage}}" mode="aspectFill" class="banner-image" />
    </swiper-item>
  </swiper>

  <!-- 场景快捷入口 -->
  <view class="section">
    <view class="section-title">场景分类</view>
    <view class="scene-grid">
      <view class="scene-item" wx:for="{{scenes}}" wx:key="name"
            bindtap="goSceneSearch" data-scene="{{item.name}}">
        <view class="scene-icon">{{item.icon}}</view>
        <text class="scene-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 热门攻略 -->
  <view class="section">
    <view class="section-title">热门攻略</view>
    <view class="guide-list">
      <guide-card wx:for="{{hotGuides}}" wx:key="_id" guide="{{item}}" bind:tap="goDetail" data-id="{{item._id}}" />
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon">⏳</view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空数据提示 -->
  <view class="empty" wx:if="{{!loading && hotGuides.length === 0}}">
    <text class="empty-icon">📷</text>
    <text class="empty-text">暂无攻略</text>
  </view>
</view>
