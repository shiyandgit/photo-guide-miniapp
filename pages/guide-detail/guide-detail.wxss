.container { padding-bottom: 120rpx; }
.cover-wrapper { width: 100%; height: 400rpx; }
.cover-image { width: 100%; height: 100%; }
.cover-fallback { box-sizing: border-box; padding: 70rpx 40rpx; color: #fff; display: flex; flex-direction: column; justify-content: flex-end; }
.cover-scene { font-size: 26rpx; opacity: 0.85; margin-bottom: 12rpx; }
.cover-title { font-size: 46rpx; font-weight: 700; line-height: 1.2; }
.notice { margin: 20rpx 20rpx 0; padding: 18rpx 22rpx; border-radius: 12rpx; color: #8a5a00; background: #fff4d8; font-size: 24rpx; }
.info-card { background-color: #fff; margin: -40rpx 20rpx 20rpx; border-radius: 16rpx; padding: 30rpx; position: relative; z-index: 10; }
.title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
.summary { color: #666; font-size: 28rpx; line-height: 1.6; margin-bottom: 22rpx; }
.tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; }
.tag-primary { background-color: rgba(74, 144, 217, 0.1); color: #4A90D9; }
.tag-orange { background-color: rgba(255, 152, 0, 0.1); color: #FF9800; }
.tag-green { background-color: rgba(76, 175, 80, 0.1); color: #4CAF50; }
.tag-blue { background-color: rgba(33, 150, 243, 0.1); color: #2196F3; }
.tag-outline { background-color: transparent; border: 1rpx solid #ddd; color: #666; }
.tag-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.tag-list { display: inline-flex; gap: 12rpx; }
.meta { display: flex; justify-content: space-between; align-items: center; }
.author { display: flex; align-items: center; }
.author-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; margin-right: 12rpx; }
.author-name { font-size: 26rpx; color: #666; }
.stats { display: flex; gap: 20rpx; }
.stat-item { font-size: 24rpx; color: #999; }
.content-card { background-color: #fff; margin: 20rpx; border-radius: 16rpx; padding: 30rpx; }
.content-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
.content-body { font-size: 28rpx; color: #666; line-height: 1.8; }
.images-card { background-color: #fff; margin: 20rpx; border-radius: 16rpx; padding: 30rpx; }
.image-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.grid-image { width: calc(33.33% - 8rpx); height: 200rpx; border-radius: 8rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background-color: #fff; display: flex; justify-content: space-around; padding: 20rpx 0; box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05); z-index: 100; }
.action-btn { display: flex; flex-direction: column; align-items: center; background: none; border: none; padding: 0; margin: 0; line-height: 1; }
.action-btn::after { border: none; }
.action-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.action-text { font-size: 24rpx; color: #666; }
.favorited .action-text { color: #4A90D9; }
.share-btn { background: none !important; }
