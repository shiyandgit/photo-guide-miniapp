<view class="container">
  <view class="search-header">
    <view class="search-box">
      <input class="search-input" placeholder="搜索拍照攻略" value="{{keyword}}" bindinput="onInput" bindconfirm="doSearch" confirm-type="search" />
      <view class="search-btn" bindtap="doSearch">搜索</view>
    </view>
  </view>
  <view wx:if="{{!keyword && !searched}}">
    <view class="section" wx:if="{{hotKeywords.length > 0}}">
      <view class="section-title">🔥 热门搜索</view>
      <view class="tag-list">
        <view class="tag-item" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="searchKeyword" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>
    <view class="section" wx:if="{{searchHistory.length > 0}}">
      <view class="section-header">
        <view class="section-title">🐾 搜索历史</view>
        <view class="clear-btn" bindtap="clearHistory">清空</view>
      </view>
      <view class="tag-list">
        <view class="tag-item" wx:for="{{searchHistory}}" wx:key="*this" bindtap="searchKeyword" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>
  <view class="filter-bar" wx:if="{{searched}}">
    <view class="filter-item {{contentType === 0 ? 'active' : ''}}" bindtap="setContentType" data-type="0">全部</view>
    <view class="filter-item {{contentType === 1 ? 'active' : ''}}" bindtap="setContentType" data-type="1">专业学习</view>
    <view class="filter-item {{contentType === 2 ? 'active' : ''}}" bindtap="setContentType" data-type="2">应急技巧</view>
  </view>
  <view class="notice" wx:if="{{errorMessage}}"><text>{{errorMessage}}</text></view>
  <view class="result-list" wx:if="{{searched}}">
    <skeleton loading="{{loading && guides.length === 0}}" type="list" count="5" />
    <block wx:if="{{guides.length > 0}}">
      <guide-card wx:for="{{guides}}" wx:key="_id" guide="{{item}}" bind:tap="goDetail" data-id="{{item._id}}" />
    </block>
    <view class="loading" wx:if="{{loading && guides.length > 0}}"><text class="loading-text">加载中...</text></view>
    <view class="empty" wx:if="{{!loading && guides.length === 0}}"><text class="empty-icon">🐱</text><text class="empty-text">没有找到呢，喵~</text></view>
    <view class="no-more" wx:if="{{!loading && noMore && guides.length > 0}}"><text class="no-more-text">没有更多了</text></view>
  </view>
</view>
