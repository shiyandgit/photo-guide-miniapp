.container { min-height: 100vh; background-color: #F0F4F8; padding-bottom: 130rpx; }
.search-header { background: linear-gradient(135deg, #4A90D9 0%, #7CB9E8 100%); padding: 20rpx; position: sticky; top: 0; z-index: 100; }
.search-box { display: flex; align-items: center; background-color: #fff; border-radius: 40rpx; padding: 8rpx; }
.search-input { flex: 1; height: 64rpx; padding: 0 24rpx; font-size: 28rpx; }
.search-btn { background-color: #4A90D9; color: #fff; padding: 12rpx 32rpx; border-radius: 32rpx; font-size: 28rpx; }
.section { background-color: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; }
.clear-btn { font-size: 24rpx; color: #999; }
.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-item { background-color: #F0F4F8; padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 26rpx; color: #666; }
.filter-bar { display: flex; background-color: #fff; padding: 16rpx 20rpx; margin-bottom: 20rpx; gap: 20rpx; }
.filter-item { font-size: 28rpx; color: #666; padding: 8rpx 0; }
.filter-item.active { color: #4A90D9; border-bottom: 4rpx solid #4A90D9; }
.notice { margin: 0 20rpx 20rpx; padding: 18rpx 22rpx; border-radius: 12rpx; color: #8a5a00; background: #fff4d8; font-size: 24rpx; }
.result-list { padding: 0 10rpx; }
.loading { text-align: center; padding: 30rpx; }
.loading-text { font-size: 26rpx; color: #999; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.no-more { text-align: center; padding: 30rpx; }
.no-more-text { font-size: 26rpx; color: #999; }
