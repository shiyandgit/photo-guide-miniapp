.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 引导页 */
.guide-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}

.guide-illustration {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.guide-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.guide-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 60rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.platform-info {
  display: flex;
  align-items: center;
}

.platform-label {
  font-size: 26rpx;
  color: #999;
}

.platform-name {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.settings-link {
  font-size: 26rpx;
  color: #FF6B6B;
}

/* 选择照片 */
.photo-section {
  margin: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background-color: #fafafa;
}

.photo-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.photo-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.photo-tip {
  font-size: 24rpx;
  color: #999;
}

.photo-preview {
  width: 100%;
  height: 400rpx;
}

/* 重新选择 */
.rechoose {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #FF6B6B;
}

/* 分析按钮 */
.analyze-btn {
  margin: 20rpx 40rpx;
}

/* 分析结果 */
.result-section {
  margin: 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.result-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}

.result-tab.active {
  color: #FF6B6B;
  border-bottom: 4rpx solid #FF6B6B;
  font-weight: bold;
}

.result-content {
  padding: 30rpx;
}

.result-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.copy-btn {
  margin-top: 30rpx;
  background-color: #f5f5f5;
  color: #FF6B6B;
  font-size: 28rpx;
  border-radius: 40rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.copy-btn::after {
  border: none;
}

.result-model {
  padding: 16rpx 30rpx;
  font-size: 22rpx;
  color: #999;
  text-align: right;
  border-top: 1rpx solid #eee;
}

/* 历史记录 */
.history-link {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #666;
}
