<view class="container">
  <!-- 未配置 API Key 时显示引导页 -->
  <view class="guide-page" wx:if="{{!hasApiKey}}">
    <view class="guide-illustration">🤖</view>
    <view class="guide-title">AI 照片评析</view>
    <view class="guide-desc">
      AI 评析需要您配置自己的 API Key，就像打印机需要自己的墨盒～
    </view>
    <view class="guide-tip">
      系统不收费，使用您自己的 API Key 完全免费
    </view>
    <button class="btn-primary" bindtap="goApiSettings">去配置 API Key</button>
  </view>

  <!-- 已配置 API Key 时显示正常分析页 -->
  <view class="analyze-page" wx:else>
    <!-- 顶部状态 -->
    <view class="status-bar">
      <view class="platform-info">
        <text class="platform-label">当前平台：</text>
        <text class="platform-name">{{platformName}}</text>
      </view>
      <view class="settings-link" bindtap="goApiSettings">API 设置</view>
    </view>

    <!-- 选择照片区域 -->
    <view class="photo-section" bindtap="choosePhoto">
      <view wx:if="{{!photoPath}}" class="photo-placeholder">
        <view class="photo-icon">📷</view>
        <text class="photo-text">点击选择照片</text>
        <text class="photo-tip">支持从相册选择或拍照</text>
      </view>
      <image wx:else src="{{photoPath}}" mode="aspectFill" class="photo-preview" />
    </view>

    <!-- 重新选择 -->
    <view class="rechoose" wx:if="{{photoPath}}" bindtap="choosePhoto">
      重新选择照片
    </view>

    <!-- 分析按钮 -->
    <button class="btn-primary analyze-btn" bindtap="startAnalysis"
            disabled="{{!photoPath || analyzing}}" loading="{{analyzing}}">
      {{analyzing ? 'AI 分析中...' : '开始分析'}}
    </button>

    <!-- 分析结果 -->
    <view class="result-section" wx:if="{{result}}">
      <view class="result-tabs">
        <view class="result-tab {{currentTab === 'suggestion' ? 'active' : ''}}"
              bindtap="switchTab" data-tab="suggestion">
          拍摄建议
        </view>
        <view class="result-tab {{currentTab === 'prompt' ? 'active' : ''}}"
              bindtap="switchTab" data-tab="prompt">
          P图提示词
        </view>
      </view>

      <!-- 拍摄建议 -->
      <view class="result-content" wx:if="{{currentTab === 'suggestion'}}">
        <view class="result-text">{{result.suggestionText}}</view>
      </view>

      <!-- P图提示词 -->
      <view class="result-content" wx:if="{{currentTab === 'prompt'}}">
        <view class="result-text">{{result.promptText}}</view>
        <button class="copy-btn" bindtap="copyPrompt">一键复制</button>
      </view>

      <view class="result-model">
        使用模型：{{result.aiModel}}
      </view>
    </view>

    <!-- 历史记录入口 -->
    <view class="history-link" bindtap="goHistory">
      查看分析历史
    </view>
  </view>
</view>
