.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 999; background: #fff; border-radius: 24rpx 24rpx 0 0; box-shadow: 0 -4rpx 20rpx rgba(74, 144, 217, 0.08); }
.tab-bar-inner { display: flex; justify-content: space-around; align-items: center; height: 110rpx; padding: 0 10rpx; }
.tab-bar-safe { padding-bottom: env(safe-area-inset-bottom); background: #fff; border-radius: 0 0 24rpx 24rpx; }
.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; padding: 8rpx 0; position: relative; }
.tab-icon-wrap { position: relative; display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; margin-bottom: 4rpx; }
.tab-icon-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 32rpx; background: linear-gradient(135deg, #E8F4FD 0%, #D0E8F9 100%); animation: popIn 0.25s ease-out; }
@keyframes popIn { 0% { transform: scale(0.6); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
.tab-icon { position: relative; z-index: 1; font-size: 40rpx; line-height: 1; transition: transform 0.2s ease; }
.tab-item.active .tab-icon { transform: scale(1.15); }
.tab-label { font-size: 22rpx; color: #999; line-height: 1; transition: color 0.2s ease; }
.tab-item.active .tab-label { color: #4A90D9; font-weight: 600; }
