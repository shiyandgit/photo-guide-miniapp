<view class="guide-card" bindtap="onTap">
  <image wx:if="{{guide.coverImage}}" class="card-cover" src="{{guide.coverImage}}" mode="aspectFill" />
  <view wx:else class="card-cover card-cover-fallback" style="background: {{guide.coverColor || '#4A90D9'}};">
    <text class="cover-scene">{{guide.scene}}</text>
  </view>
  <view class="card-info">
    <text class="card-title">{{guide.title}}</text>
    <text class="card-summary" wx:if="{{guide.summary}}">{{guide.summary}}</text>
    <view class="card-tags">
      <view class="card-tag {{guide.contentType === 1 ? 'tag-primary' : 'tag-orange'}}">
        {{guide.contentType === 1 ? '专业学习' : '应急技巧'}}
      </view>
    </view>
    <view class="card-meta">
      <text class="card-stat">❤️ {{guide.favoriteCount || 0}}</text>
    </view>
  </view>
</view>
