<view class="skeleton" wx:if="{{loading}}">
  <view class="skeleton-header" wx:if="{{type === 'detail'}}">
    <view class="skel skel-cover"></view>
    <view class="skel-card">
      <view class="skel skel-title"></view>
      <view class="skel skel-line" style="width: 80%"></view>
      <view class="skel skel-line" style="width: 60%"></view>
      <view class="skel-tags">
        <view class="skel skel-tag"></view>
        <view class="skel skel-tag"></view>
        <view class="skel skel-tag" style="width: 80rpx"></view>
      </view>
    </view>
    <view class="skel-card">
      <view class="skel skel-line"></view>
      <view class="skel skel-line" style="width: 90%"></view>
      <view class="skel skel-line" style="width: 95%"></view>
      <view class="skel skel-line" style="width: 70%"></view>
      <view class="skel-gap"></view>
      <view class="skel skel-line"></view>
      <view class="skel skel-line" style="width: 85%"></view>
    </view>
  </view>
  <view class="skeleton-home" wx:if="{{type === 'home'}}">
    <view class="skel-search-bar">
      <view class="skel skel-search-input"></view>
    </view>
    <view class="skel skel-banner"></view>
    <view class="skel-grid">
      <view class="skel-grid-item" wx:for="{{[1,2,3,4,5,6,7,8]}}" wx:key="*this">
        <view class="skel skel-circle"></view>
        <view class="skel skel-grid-text"></view>
      </view>
    </view>
    <view class="skel-section-title">
      <view class="skel skel-line" style="width: 160rpx"></view>
    </view>
    <view class="skel-guide-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skel skel-guide-cover"></view>
      <view class="skel-guide-info">
        <view class="skel skel-line" style="width: 70%"></view>
        <view class="skel skel-line" style="width: 90%"></view>
        <view class="skel skel-line" style="width: 50%"></view>
      </view>
    </view>
  </view>
  <view class="skeleton-list" wx:if="{{type === 'list'}}">
    <view class="skel-guide-card" wx:for="{{count || 3}}" wx:key="*this">
      <view class="skel skel-guide-cover"></view>
      <view class="skel-guide-info">
        <view class="skel skel-line" style="width: 70%"></view>
        <view class="skel skel-line" style="width: 90%"></view>
        <view class="skel skel-line" style="width: 50%"></view>
      </view>
    </view>
  </view>
</view>
